# Bash aliases
alias ll='ls -la'
alias ..='cd ..'
alias ...='cd ../..'

# Git aliases
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gu='git pull'
alias gl='git log --oneline --graph --all'
alias gd="git diff --output-indicator-new=' ' --output-indicator-old=' '"
alias gb='git branch'
alias gi='git init'
alias gcl='git clone'
